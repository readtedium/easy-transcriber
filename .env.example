# Copy to .env and fill in your key,
# OR leave blank and enter it in the UI instead.
DEEPGRAM_API_KEY=
DEEPSEEK_API_KEY=
SERVER_PORT=3000

# Optional — enable password protection
LOGIN_PASSWORD=
# Recommended when LOGIN_PASSWORD is set (random string); auto-generated if omitted
SESSION_SECRET=

# Optional — override Moonshine sidecar URL (default: http://moonshine:8765)
# Only needed if running Moonshine outside Docker or on a different host
# MOONSHINE_URL=http://moonshine:8765